from __future__ import annotations

from aiogram.types import InlineKeyboardButton, InlineKeyboardMarkup


def build_main_keyboard() -> InlineKeyboardMarkup:
    rows = [
        [
            InlineKeyboardButton(text="Labs", callback_data="ask:what labs are available"),
            InlineKeyboardButton(text="Students", callback_data="ask:how many students are enrolled"),
        ],
        [
            InlineKeyboardButton(text="Scores L1", callback_data="ask:show me scores for lab 1"),
            InlineKeyboardButton(text="Scores L2", callback_data="ask:show me scores for lab 2"),
        ],
        [
            InlineKeyboardButton(text="Scores L3", callback_data="ask:show me scores for lab 3"),
            InlineKeyboardButton(text="Scores L4", callback_data="ask:show me scores for lab 4"),
        ],
        [
            InlineKeyboardButton(text="Scores L5", callback_data="ask:show me scores for lab 5"),
            InlineKeyboardButton(text="Scores L6", callback_data="ask:show me scores for lab 6"),
        ],
        [
            InlineKeyboardButton(text="Scores L7", callback_data="ask:show me scores for lab 7"),
            InlineKeyboardButton(text="Pass Rate L4", callback_data="ask:show me pass rates for lab 4"),
        ],
        [
            InlineKeyboardButton(text="Best Group L3", callback_data="ask:which group is doing best in lab 3"),
            InlineKeyboardButton(text="Top 5", callback_data="ask:who are the top 5 students"),
        ],
        [
            InlineKeyboardButton(text="Lowest Pass", callback_data="ask:which lab has the lowest pass rate"),
            InlineKeyboardButton(text="Highest Pass", callback_data="ask:which lab has the highest pass rate"),
        ],
        [
            InlineKeyboardButton(text="Completion L5", callback_data="ask:what is the completion rate for lab 5"),
            InlineKeyboardButton(text="Timeline L4", callback_data="ask:show the timeline for lab 4"),
        ],
        [
            InlineKeyboardButton(text="Learners", callback_data="ask:show learners"),
            InlineKeyboardButton(text="Sync", callback_data="ask:sync the data"),
        ],
        [
            InlineKeyboardButton(text="Help", callback_data="cmd:/help"),
            InlineKeyboardButton(text="Health", callback_data="cmd:/health"),
        ],
    ]
    return InlineKeyboardMarkup(inline_keyboard=rows)
